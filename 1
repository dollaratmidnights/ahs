function submitForm() {
  const url = "https://script.google.com/macros/s/AKfycbyvC5vXwgg6Vpxb60c0kygFcCBCup8CQL9KoJTEkAMKbcUEGmPJfc9oBYTHNGEhqI4/exec";
  const payload = {
    action: "register",
    name: document.getElementById("name").value,
    studentId: document.getElementById("studentId").value,
    rank1: document.getElementById("rank1").value,
    rank2: document.getElementById("rank2").value,
    rank3: document.getElementById("rank3").value
  };

  fetch(url, {
    method: "POST",
    body: JSON.stringify(payload)
  }).then(response => {
    alert("สมัครสตาฟสำเร็จ!");
  });
}
